# ──────────────────────────────────────────────────
# Environment Variables Template
# ──────────────────────────────────────────────────
# คัดลอกไฟล์นี้เป็น .env แล้วใส่ค่าจริง
#
# วิธีใช้:
#   cp .env.example .env
#   nano .env   # หรือเปิดด้วย editor ที่ชอบ
#
# คำเตือน: ห้าม commit .env เข้า git
# ──────────────────────────────────────────────────

# โหมดของแอป: development | staging | production
APP_ENV=development

# Encryption key สำหรับ SQLite (สร้างใหม่ทุก install ใน production)
# สำหรับ development ใช้ค่า dummy ได้
# สำหรับ production: ค่านี้จะถูกสร้างและเก็บใน secure storage แทน
DB_ENCRYPTION_KEY_DEV=dev_only_dummy_key_change_in_production

# Firebase (จะใช้ใน Batch 7 — ตอน analytics + crashlytics)
# FIREBASE_PROJECT_ID=
# FIREBASE_API_KEY_IOS=
# FIREBASE_API_KEY_ANDROID=
# FIREBASE_APP_ID_IOS=
# FIREBASE_APP_ID_ANDROID=

# Sentry (alternative สำหรับ crash reporting — เลือกเอา)
# SENTRY_DSN=

# Privacy Policy / ToS URLs
PRIVACY_POLICY_URL=https://moneydiary.app/privacy
TERMS_OF_SERVICE_URL=https://moneydiary.app/terms
SUPPORT_EMAIL=support@moneydiary.app
